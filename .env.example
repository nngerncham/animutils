# Copy to .env and fill in.

# MyAnimeList — https://myanimelist.net/apiconfig
MAL_CLIENT_ID=
MAL_CLIENT_SECRET=
MAL_REDIRECT_URI=http://localhost:8765/callback

# Path to the Google OAuth Desktop-app client_secret JSON downloaded from
# Google Cloud Console. Relative paths resolve from the repo root.
GOOGLE_CLIENT_SECRET_FILE=google_client_secret.json

# Calendar to push events into (use "primary" for your main calendar).
GOOGLE_CALENDAR_ID=primary
